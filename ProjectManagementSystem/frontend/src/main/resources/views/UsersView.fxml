<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pms.controllers.UsersController">
   <content>
      <VBox spacing="20.0" style="-fx-background-color: transparent;">
         <children>
            <Label text="User Management" textFill="#D1C0EC">
               <font>
                  <Font name="System Bold" size="28.0" />
               </font>
            </Label>
            <VBox spacing="10.0" styleClass="card" style="-fx-padding: 30;">
               <children>
                  <Label text="Add New Faculty or Student" textFill="#C4ADDD">
                     <font>
                        <Font name="System Bold" size="16.0" />
                     </font>
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Label>
                  
                  <Label text="Full Name" textFill="#8D77A8" />
                  <TextField fx:id="nameField" prefHeight="45.0" promptText="Enter full name" styleClass="modern-text-field" />
                  
                  <Label text="Email Address" textFill="#8D77A8">
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                  </Label>
                  <TextField fx:id="emailField" prefHeight="45.0" promptText="email@example.com" styleClass="modern-text-field" />
                  
                  <Label text="Temporary Password" textFill="#8D77A8">
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                  </Label>
                  <PasswordField fx:id="passwordField" prefHeight="45.0" promptText="At least 6 characters" styleClass="modern-text-field" />
                  
                  <Label text="Role" textFill="#8D77A8">
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                  </Label>
                  <ComboBox fx:id="roleSelector" prefHeight="45.0" prefWidth="500.0" promptText="Select Role" styleClass="modern-text-field" />
                  
                  <Button fx:id="addButton" mnemonicParsing="false" onAction="#handleAddUser" prefHeight="50.0" prefWidth="500.0" styleClass="modern-button" text="CREATE USER ACCOUNT">
                     <VBox.margin>
                        <Insets top="20.0" />
                     </VBox.margin>
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Button>
                  <Label fx:id="statusLabel" alignment="CENTER" prefWidth="500.0" textAlignment="CENTER" />
               </children>
            </VBox>
      
            <VBox spacing="10.0" styleClass="card" style="-fx-padding: 30;">
               <children>
                  <Label text="Bulk User Upload" textFill="#C4ADDD">
                     <font>
                        <Font name="System Bold" size="16.0" />
                     </font>
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Label>
                  <Label text="Upload CSV or XLSX files (Attendance/Student lists). Our AI will automatically map the columns and detect gaps." textFill="#8D77A8" wrapText="true" />
                  
                  <Button fx:id="bulkUploadButton" mnemonicParsing="false" onAction="#handleBulkUpload" prefHeight="50.0" prefWidth="500.0" style="-fx-background-color: transparent; -fx-border-color: #8D77A8; -fx-border-radius: 5; -fx-text-fill: #D1C0EC;" text="📁 UPLOAD SPREADSHEET">
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Button>
                  <Label fx:id="bulkStatusLabel" alignment="CENTER" prefWidth="500.0" textAlignment="CENTER" />
               </children>
            </VBox>
         </children>
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
      </VBox>
   </content>
</ScrollPane>
