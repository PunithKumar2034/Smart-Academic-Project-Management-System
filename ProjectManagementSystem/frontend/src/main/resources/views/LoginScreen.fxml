<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #121212;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pms.controllers.LoginController">
   <children>
      <Pane prefHeight="600.0" prefWidth="450.0" style="-fx-background-color: linear-gradient(to bottom right, #2b5876, #4e4376);">
         <children>
            <Label layoutX="60.0" layoutY="250.0" text="Smart Academic" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="36.0" />
               </font>
            </Label>
            <Label layoutX="60.0" layoutY="300.0" text="Project Management System" textFill="#dcdcdc">
               <font>
                  <Font size="20.0" />
               </font>
            </Label>
         </children>
      </Pane>
      <VBox alignment="CENTER" layoutX="520.0" layoutY="100.0" prefHeight="400.0" prefWidth="300.0" spacing="20.0">
         <children>
            <Label text="Welcome Back" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="28.0" />
               </font>
            </Label>
            <Label text="Login to continue" textFill="#a0a0a0" />
            <TextField fx:id="emailField" prefHeight="40.0" promptText="Email Address" styleClass="modern-text-field" />
            <PasswordField fx:id="passwordField" prefHeight="40.0" promptText="Password" styleClass="modern-text-field" />
            <Button fx:id="loginButton" mnemonicParsing="false" onAction="#handleLogin" prefHeight="45.0" prefWidth="300.0" styleClass="modern-button" text="LOGIN" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Button>
            <Label fx:id="statusLabel" />
            <Label text="Forgot Password?" textFill="#00a8ff" underline="true" style="-fx-cursor: hand;" />
         </children>
      </VBox>
   </children>
</AnchorPane>
