<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="768.0" prefWidth="764.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pms.controllers.TeamsController">
   <top>
      <VBox spacing="15.0" BorderPane.alignment="CENTER">
         <BorderPane.margin>
            <Insets bottom="20.0" left="30.0" right="30.0" top="30.0" />
         </BorderPane.margin>
         <children>
            <HBox alignment="CENTER_LEFT">
               <children>
                  <Label text="Team Management" textFill="#D1C0EC">
                     <font>
                        <Font name="System Bold" size="28.0" />
                     </font>
                  </Label>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnAutoForm" mnemonicParsing="false" onAction="#handleAutoFormTeams" styleClass="modern-button" text="Form Teams (Auto)">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
            
            <HBox spacing="15.0">
               <children>
                  <TextField fx:id="searchField" prefHeight="40.0" prefWidth="300.0" promptText="Search teams by name..." styleClass="modern-text-field" />
                  <ComboBox fx:id="projectFilter" prefHeight="40.0" prefWidth="250.0" promptText="Filter by Project" styleClass="modern-text-field" />
               </children>
            </HBox>
         </children>
      </VBox>
   </top>
   
   <center>
      <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" BorderPane.alignment="CENTER">
         <BorderPane.margin>
            <Insets bottom="30.0" left="30.0" right="30.0" />
         </BorderPane.margin>
         <content>
            <FlowPane fx:id="teamsFlowPane" hgap="20.0" vgap="20.0" />
         </content>
      </ScrollPane>
   </center>
</BorderPane>
