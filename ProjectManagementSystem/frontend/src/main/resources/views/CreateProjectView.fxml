<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="500.0" spacing="20.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pms.controllers.CreateProjectController">
   <children>
      <Label text="Create New Project" textFill="#D1C0EC">
         <font>
            <Font name="System Bold" size="28.0" />
         </font>
      </Label>
      <VBox spacing="10.0" styleClass="card" style="-fx-padding: 30;">
         <children>
            <Label text="Project Name" textFill="#8D77A8" />
            <TextField fx:id="nameField" prefHeight="45.0" promptText="Enter project name" styleClass="modern-text-field" />
            
            <Label text="Select Subject" textFill="#8D77A8">
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Label>
            <ComboBox fx:id="subjectSelector" prefHeight="45.0" prefWidth="500.0" promptText="Select an academic subject" styleClass="modern-text-field" />
            
            <Label text="Description" textFill="#8D77A8">
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Label>
            <TextArea fx:id="descArea" prefHeight="120.0" promptText="Describe the project goals and requirements..." styleClass="modern-text-field" wrapText="true" />
            
            <Label text="Max Team Size" textFill="#8D77A8">
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Label>
            <Spinner fx:id="teamSizeSpinner" prefHeight="40.0" prefWidth="120.0" />
            
            <Label text="Submission Deadline (Optional)" textFill="#8D77A8">
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Label>
            <javafx.scene.control.DatePicker fx:id="deadlinePicker" prefHeight="45.0" prefWidth="500.0" promptText="Select final submission date" styleClass="modern-text-field" />
            
            <Button fx:id="submitButton" mnemonicParsing="false" onAction="#handleSubmit" prefHeight="50.0" prefWidth="500.0" styleClass="modern-button" text="SUBMIT PROJECT">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Button>
            <Label fx:id="statusLabel" alignment="CENTER" prefWidth="500.0" textAlignment="CENTER" />
         </children>
      </VBox>
   </children>
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
</VBox>
